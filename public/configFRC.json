{
  "category": "FRC",
  "version": "2.0.0",
  "PREMATCH": [
    {
      "label": "Scouter Name",
      "key": "scouter_name",
      "type": "text",
      "required": true
    },
    {
      "label": "Match Number",
      "key": "match_number",
      "type": "number",
      "required": true,
      "allowZero": false
    },
    {
      "label": "Robot Position",
      "key": "robot_position",
      "type": "dropdown",
      "options": ["Blue 1", "Blue 2", "Blue 3", "Red 1", "Red 2", "Red 3"],
      "required": true
    },
    {
      "label": "Team Number",
      "key": "team_number",
      "type": "number",
      "required": true,
      "allowZero": false
    },
    {
      "label": "Starting Position",
      "key": "starting_position",
      "type": "dropdown",
      "options": ["Outpost Side", "Middle", "Depot Side"],
      "required": true
    }
  ],
  "AUTONOMOUS": [
    {
      "label": "Shoot Time",
      "key": "auton_shoot_time",
      "type": "chrono"
    },
    {
      "label": "Shoot amount",
      "key": "auto_shoot_amount",
      "type": "dropdown",
      "options": ["None", "Too little (Less than 15)", "Some (15-30)", "Many (30-60)", "Too many (More than 60)"],
      "required": true
    },
    {
      "label": "Pass amount",
      "key": "auto_pass_amount",
      "type": "dropdown",
      "options": ["None", "Too little (Less than 15)", "Some (15-30)", "Many (30-60)", "Too many (More than 60)"]
    },
    {
      "label": "Climb Position",
      "key": "auto_climb_position",
      "type": "dropdown",
      "options": ["Middle", "Side", "Didn't Climb", "Failed Climb Attempt","None"],
      "required": true
    },
    {
      "label": "If climbed, Got stuck in Tower?",
      "key": "auto_descends_stuck",
      "type": "switch"
    },
    {
      "label": "Auton Complexity",
      "key": "auto_complexity",
      "type": "dropdown",
      "options": ["Did Nothing", "Only Moved", "Only Shot","Moves Balls in Middle", "Good", "Excellent"],
      "required": true
    },
    {
      "label": "Auton Completed?",
      "key": "auto_completed",
      "type": "switch"
    },
    {
      "label": "How much missed shots?",
      "key": "auto_missed_shots",
      "type": "dropdown",
      "options": ["0%(ask before)", "10%", "25%", "50%", "75%", "100%"]
    }
  ],
  "TELEOP": [
    {
      "label": "Shoot Time",
      "key": "teleop_shoot_time",
      "type": "chrono"
    },
    {
      "label": "Pass Time",
      "key": "teleop_pass_time",
      "type": "chrono"
    },
    {
      "label": "Shoot amount",
      "key": "teleop_shoot_amount",
      "type": "dropdown",
      "options": ["None", "Too little (Less than 35)", "Some (35-60)", "Many (60-90)", "Too many (90-130)", "Capitan (More than 130)"],
      "required": true
    },
    {
      "label": "Pass amount",
      "key": "teleop_pass_amount",
      "type": "dropdown",
      "options": ["None", "Too little (Less than 35)", "Some (35-60)", "Many (60-90)", "Too many (90-130)", "Support (More than 130)"]
    },
    {
      "label": "Penalty Counter",
      "key": "teleop_penalty",
      "type": "counter"
    },
    {
      "label": "How much missed shots?",
      "key": "teleop_missed_shots",
      "type": "dropdown",
      "options": ["0%(ask before)", "10%", "25%", "50%", "75%", "100%"]
    },
    {
      "label": "Quality Chasis/Driver Movement",
      "key": "teleop_chassis_movement",
      "type": "dropdown",
      "options": ["None", "Bad", "Mid", "Good", "BestOfEvent"],
      "required": true
    }
  ],
  "ENDGAME": [
    {
      "label": "Climb",
      "key": "endgame_climb",
      "type": "dropdown",
      "options": ["None", "Didn't Climb", "L1", "L2", "L3", "Failed Climb Attempt"],
      "required": true
    },
    {
      "label": "Jammed over balls?",
      "key": "endgame_jammed_over_balls",
      "type": "switch"
    },
    {
      "label": "Bulldozing?",
      "key": "endgame_bulldozing",
      "type": "dropdown",
      "options": ["None", "Bad", "Mid", "Good", "BestOfEvent"],
      "required": true
    },
    {
      "label": "Defended?",
      "key": "endgame_defended",
      "type": "dropdown",
      "options": ["None", "Bad", "Mid", "Good", "BestOfEvent", "Trobots(PreguntaAntesDePoner)"],
      "required": true
    },
    {
      "label": "Chasis Type",
      "key": "endgame_chassis_type",
      "type": "dropdown",
      "options": ["Tank", "Mecanum", "Swerve"],
      "required": true
    },
    {
      "label": "Died",
      "key": "teleop_died",
      "type": "switch"
    },
    {
      "label": "Comments? (Keep it short, only relevant info)",
      "key": "endgame_comments",
      "type": "textarea"
    }
  ]
}
