{
  "category": "FRC",
  "version": "0.1.1",
  "PREMATCH": [
    {
      "label": "Scouter Name",
      "key": "scouter_name",
      "type": "text",
      "required": true
    },
    {
      "label": "Match Number",
      "key": "match_number",
      "type": "number",
      "required": true,
      "allowZero": false
    },
    {
      "label": "Robot Position",
      "key": "robot_position",
      "type": "dropdown",
      "options": ["Blue 1", "Blue 2", "Blue 3", "Red 1", "Red 2", "Red 3"],
      "required": true
    },
    {
      "label": "Team Number",
      "key": "team_number",
      "type": "number",
      "required": true,
      "allowZero": false
    },
    {
      "label": "Starting Position",
      "key": "starting_position",
      "type": "dropdown",
      "options": ["Outpost Side", "Middle", "Depot Side"],
      "required": true
    }
  ],
  "AUTONOMOUS": [
    {
      "label": "Shoot Time",
      "key": "auto_shoot_time",
      "type": "chrono"
    },
    {
      "label": "Pass Time",
      "key": "auto_pass_time",
      "type": "chrono"
    },
    {
      "label": "Climb Position",
      "key": "auto_climb_position",
      "type": "dropdown",
      "options": ["Middle", "Side", "Didn't Climb", "Failed Climb Attempt","None"],
      "required": true
    },
    {
      "label": "If climbed, Got stuck in Tower?",
      "key": "auto_descends_stuck",
      "type": "switch"
    },
    {
      "label": "Auton Complexity",
      "key": "auto_complexity",
      "type": "dropdown",
      "options": ["Did Nothing", "Only Moved", "Only Shot","Moves Balls in Middle", "Good", "Excellent"],
      "required": true
    },
    {
      "label": "Auton Completed?",
      "key": "auto_completed",
      "type": "switch"
    },
    {
      "label": "How much missed shots?",
      "key": "auto_missed_shots",
      "type": "dropdown",
      "options": ["0%(ask before)", "10%", "25%", "50%", "75%", "100%"]
    }
  ],
  "TELEOP": [
    {
      "label": "Shoot Time",
      "key": "teleop_shoot_time",
      "type": "chrono"
    },
    {
      "label": "Pass Time",
      "key": "teleop_pass_time",
      "type": "chrono"
    },
    {
      "label": "Penalty Counter",
      "key": "teleop_penalty",
      "type": "counter"
    },
    {
      "label": "How much missed shots?",
      "key": "teleop_missed_shots",
      "type": "dropdown",
      "options": ["0%(ask before)", "10%", "25%", "50%", "75%", "100%"]
    },
    {
      "label": "Quality Chasis/Driver Movement",
      "key": "teleop_chassis_movement",
      "type": "dropdown",
      "options": ["None", "Bad", "Mid", "High"],
      "required": true
    }
  ],
  "ENDGAME": [
    {
      "label": "Climb",
      "key": "endgame_climb",
      "type": "dropdown",
      "options": ["None", "Didn't Climb", "L1", "L2", "L3", "Failed Climb Attempt"],
      "required": true
    },
    {
      "label": "Jammed over balls?",
      "key": "endgame_jammed_over_balls",
      "type": "switch"
    },
    {
      "label": "Bulldozing?",
      "key": "endgame_bulldozing",
      "type": "dropdown",
      "options": ["None", "Bad", "Mid", "High", "BestOfEvent"],
      "required": true
    },
    {
      "label": "Defended?",
      "key": "endgame_defended",
      "type": "dropdown",
      "options": ["None", "Bad", "Mid", "High", "BestOfEvent", "Trobots(PreguntaAntesDePoner)"],
      "required": true
    },
    {
      "label": "Chasis Type",
      "key": "endgame_chassis_type",
      "type": "dropdown",
      "options": ["Tank", "Mecanum", "Swerve"]
    },
    {
      "label": "Died",
      "key": "teleop_died",
      "type": "switch"
    },
    {
      "label": "Comments? (Keep it short)",
      "key": "endgame_comments",
      "type": "text"
    }
  ]
}
